# 이 파일을 복사해 .env로 만들고 실제 값을 채워주세요.
# cp .env.example .env

# MySQL 접속 정보
DB_URL=jdbc:mysql://localhost:3306/notification_db?serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# MySQL 컨테이너 설정 (docker-compose 전용)
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=notification_db
